[Unit]
Description=Telegram Personal Assistant Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=assistant
WorkingDirectory=/home/assistant/telegram-assistant
EnvironmentFile=/home/assistant/telegram-assistant/.env
ExecStart=/home/assistant/telegram-assistant/venv/bin/python bot.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
