# ── Core ──────────────────────────────────────────────────────────────────────

# From BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=

# From console.anthropic.com
ANTHROPIC_API_KEY=

# From platform.openai.com (for Whisper voice transcription)
OPENAI_API_KEY=

# Your personal Telegram numeric user ID (get it from @userinfobot)
# Comma-separated for multiple users, e.g. 111111111,222222222
ALLOWED_USER_IDS=

# Model to use
CLAUDE_MODEL=claude-sonnet-4-6

# IANA timezone for calendar events and the assistant's sense of "now"
USER_TIMEZONE=Asia/Singapore

# Set to 1 on the headless server so OAuth flows fail fast instead of hanging.
# Leave blank locally so you can complete browser/device sign-in.
HEADLESS=

# ── Microsoft Graph (Outlook mail, Calendar, To Do) ──────────────────────────
MS_CLIENT_ID=
MS_TENANT_ID=common

# ── Urban Makers (umcpm) — Supabase ──────────────────────────────────────────
# Service-role key: Supabase dashboard → Settings → API → service_role secret.
UMCPM_SUPABASE_URL=https://rlcigpzbjuigpjnewimm.supabase.co
UMCPM_SERVICE_KEY=
UMCPM_BASE_URL=https://umcpm.netlify.app

# ── Personal blog (bryanjlum.com publishing) ─────────────────────────────────
# Fine-grained GitHub PAT (github.com/settings/tokens) scoped to ONLY the
# blog repo, with Repository permissions → Contents: Read and write.
BLOG_GITHUB_TOKEN=
# Optional overrides (defaults shown):
BLOG_REPO=eskm1/bryanjlum.com
BLOG_BRANCH=main
BLOG_POSTS_PATH=src/content/blog
BLOG_BASE_URL=https://bryanjlum.com

# ── Second brain vault (personal note capture) ───────────────────────────────
# Fine-grained GitHub PAT (github.com/settings/tokens) scoped to ONLY the
# second-brain repo, with Repository permissions → Contents: Read and write.
SECOND_BRAIN_GITHUB_TOKEN=
# Optional overrides (defaults shown):
SECOND_BRAIN_REPO=eskm1/second-brain
SECOND_BRAIN_BRANCH=main
SECOND_BRAIN_INBOX_PATH=00 Inbox/telegram.md
