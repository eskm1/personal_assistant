# ── Required for Phase 1 ──────────────────────────────────────────────────────

# From BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=

# From console.anthropic.com
ANTHROPIC_API_KEY=

# From platform.openai.com (for Whisper voice transcription)
OPENAI_API_KEY=

# Your personal Telegram numeric user ID (get it from @userinfobot)
# Comma-separated if you want multiple users, e.g. 111111111,222222222
ALLOWED_USER_IDS=

# Model to use (default shown)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Phase 3: Gmail ────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Phase 4: Microsoft Graph (Outlook mail, Calendar, To Do) ─────────────────
# MS_CLIENT_ID=
# MS_TENANT_ID=
# MS_CLIENT_SECRET=

# ── Phase 5: Google Maps ──────────────────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=

# ── Phase 6: Telethon (send Telegram DMs as yourself) ────────────────────────
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
